const fs = require('fs');
const path = require('path');

const DATA_DIR  = path.join(__dirname, '..', 'data');
const WARN_FILE = path.join(DATA_DIR, 'warnings.json');

let _cache = null;
let _cacheTime = 0;
const CACHE_TTL = 10_000;

function load() {
  const now = Date.now();
  if (_cache && now - _cacheTime < CACHE_TTL) return _cache;
  try {
    if (!fs.existsSync(DATA_DIR)) fs.mkdirSync(DATA_DIR, { recursive: true });
    if (fs.existsSync(WARN_FILE)) {
      _cache = JSON.parse(fs.readFileSync(WARN_FILE, 'utf8'));
    } else {
      _cache = {};
    }
  } catch (err) {
    console.error('[warnStore] Failed to load:', err);
    _cache = {};
  }
  _cacheTime = now;
  return _cache;
}

function save(data) {
  try {
    if (!fs.existsSync(DATA_DIR)) fs.mkdirSync(DATA_DIR, { recursive: true });
    const tmp = WARN_FILE + '.tmp';
    fs.writeFileSync(tmp, JSON.stringify(data, null, 2));
    fs.renameSync(tmp, WARN_FILE);
    _cache = data;
    _cacheTime = Date.now();
  } catch (err) {
    console.error('[warnStore] Failed to save:', err);
  }
}

function genId() {
  return Date.now().toString(36) + Math.random().toString(36).slice(2, 6);
}

function addWarning(guildId, userId, { reason, moderator, timestamp }) {
  const db = load();
  if (!db[guildId]) db[guildId] = {};
  if (!db[guildId][userId]) db[guildId][userId] = [];

  const warning = { id: genId(), reason, moderator, timestamp };
  db[guildId][userId].push(warning);
  save(db);
  return warning;
}

function getWarnings(guildId, userId) {
  const db = load();
  return db[guildId]?.[userId] ?? [];
}

function clearWarnings(guildId, userId) {
  const db = load();
  if (db[guildId]) delete db[guildId][userId];
  save(db);
}

function removeWarning(guildId, userId, warnId) {
  const db = load();
  const warns = db[guildId]?.[userId];
  if (!warns) return false;

  const idx = warns.findIndex(w => w.id === warnId);
  if (idx === -1) return false;

  warns.splice(idx, 1);
  if (warns.length === 0) delete db[guildId][userId];
  save(db);
  return true;
}

function reload() {
  _cache = null;
  _cacheTime = 0;
  return load();
}

module.exports = { addWarning, getWarnings, clearWarnings, removeWarning, reload };
